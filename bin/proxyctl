month_start_utc() {
  date -u +"%Y-%m-01 00:00:00"
}

bytes_to_human() {
  local b="${1:-0}"
  awk -v b="$b" 'BEGIN{
    split("B KiB MiB GiB TiB",u," ");
    i=1;
    while (b>=1024 && i<5) { b/=1024; i++ }
    printf "%.2f %s", b, u[i];
  }'
}

gb_to_bytes() {
  local gb="$1"
  awk -v g="$gb" 'BEGIN{printf "%.0f", g*1024*1024*1024}'
}

month_key_utc() {
  date -u +"%Y-%m"
}

month_start_epoch_utc() {
  date -u -d "$(month_start_utc)" +%s
}

usage_cache_file() {
  echo "${PROXYCTL_CACHE_DIR}/usage-$(month_key_utc).db"
}

usage_cache_init() {
  mkdir -p "$PROXYCTL_CACHE_DIR"
}

usage_cache_refresh_month() {
  usage_cache_init

  local cache_file month_start month_epoch last_ts tmp merge_tmp
  cache_file="$(usage_cache_file)"
  month_start="$(month_start_utc)"
  month_epoch="$(month_start_epoch_utc)"
  last_ts="$month_epoch"

  if [[ -f "$cache_file" ]]; then
    local cached_ts
    cached_ts="$(sed -n 's/^__last_ts=//p' "$cache_file" | head -n1)"
    if [[ "$cached_ts" =~ ^[0-9]+$ ]] && (( cached_ts >= month_epoch )); then
      last_ts="$cached_ts"
    fi
  fi

  tmp="$(mktemp)"
  merge_tmp="$(mktemp)"
  trap 'rm -f "${tmp:-}" "${merge_tmp:-}"' RETURN

  journalctl -u "$DANTED_SERVICE" --since "@${last_ts}" --grep 'tcp/connect \]:' --output=short-unix --no-pager 2>/dev/null \
    | perl -ne '
        next unless /^([0-9]+(?:\.[0-9]+)?)\s+/;
        my $ts = int($1);
        next if $ts <= '"$last_ts"';
        if (/username%([^@ ]+)@.*->\s*([0-9]+),\s*([0-9]+)\s*->/) {
          $sum{$1} += ($2 + $3);
          $max_ts = $ts if !defined($max_ts) || $ts > $max_ts;
        }
        END {
          for my $user (keys %sum) {
            print $user, " ", $sum{$user}, "\n";
          }
          print "__max_ts ", $max_ts, "\n" if defined $max_ts;
        }
      ' > "$tmp"

  if [[ ! -s "$cache_file" ]]; then
    printf "__last_ts=%s\n" "$last_ts" > "$cache_file"
  fi

  awk '$1 != "__max_ts" && NF >= 2 {print $1, $2}' "$tmp" > "$merge_tmp"
  if [[ -s "$merge_tmp" ]]; then
    awk '
      FNR == NR {
        if ($1 == "__last_ts=") next
        if ($1 !~ /^__last_ts=/ && NF >= 2) sum[$1] = $2
        next
      }
      NF >= 2 { sum[$1] += $2 }
      END {
        for (user in sum) printf "%s %d\n", user, sum[user]
      }
    ' "$cache_file" "$merge_tmp" | sort > "${cache_file}.rows"
  else
    awk '$1 !~ /^__last_ts=/ && NF >= 2 {print $1, $2}' "$cache_file" | sort > "${cache_file}.rows"
  fi

  local new_last_ts
  new_last_ts="$(awk '$1 == "__max_ts" {print $2}' "$tmp" | tail -n1)"
  if [[ ! "$new_last_ts" =~ ^[0-9]+$ ]]; then
    new_last_ts="$last_ts"
  fi

  {
    printf "__last_ts=%s\n" "$new_last_ts"
    cat "${cache_file}.rows"
  } > "${cache_file}.new"
  mv "${cache_file}.new" "$cache_file"
  rm -f "${cache_file}.rows"
}

usage_rows_cached_month() {
  usage_cache_refresh_month
  local cache_file
  cache_file="$(usage_cache_file)"
  awk '$1 !~ /^__last_ts=/ && NF >= 2 {print $1, $2}' "$cache_file"
}

usage_warm_cache() {
  need_root
  usage_cache_refresh_month
  local cache_file
  cache_file="$(usage_cache_file)"
  echo "[usage-cache]"
  echo "month: $(month_key_utc)"
  echo "file: $cache_file"
  if [[ -f "$cache_file" ]]; then
    sed -n 's/^__last_ts=/last_ts=/p' "$cache_file" | head -n1
    echo "entries: $(awk '$1 !~ /^__last_ts=/ && NF >= 2 {n++} END {print n+0}' "$cache_file")"
  fi
}

usage_rows() {
  local since="$1"
  if [[ "$since" == "$(month_start_utc)" ]]; then
    usage_rows_cached_month
    return
  fi
  journalctl -u "$DANTED_SERVICE" --since "$since" --grep 'tcp/connect \]:' --output=cat --no-pager 2>/dev/null \
    | perl -ne '
        if (/username%([^@ ]+)@.*->\s*([0-9]+),\s*([0-9]+)\s*->/) {
          $sum{$1} += ($2 + $3);
        }
        END {
          for my $user (keys %sum) {
            print $user, " ", $sum{$user}, "\n";
          }
        }
      ' \
    | sort
}

usage() {
  need_root
  local since user warm_cache
  since="$(month_start_utc)"
  user=""
  warm_cache="false"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --since)
        shift
        [[ $# -gt 0 ]] || err "--since requires a value"
        since="$1"
        ;;
      --user)
        shift
        [[ $# -gt 0 ]] || err "--user requires a value"
        user="$1"
        ;;
      --warm-cache)
        warm_cache="true"
        ;;
      -h|--help)
        print_usage_help
        return
        ;;
      *)
        err "unknown option: $1"
        ;;
    esac
    shift
  done

  if [[ "$warm_cache" == "true" ]]; then
    usage_warm_cache
    return
  fi

  local rows
  rows="$(usage_rows "$since" || true)"

  echo "[usage]"
  echo "since: $since"
  echo
  printf "%-22s %-14s %-12s\n" "user" "bytes" "human"
  printf "%-22s %-14s %-12s\n" "----------------------" "--------------" "------------"

  if [[ -z "$rows" ]]; then
    echo "no data"
    return
  fi

  local total=0
  while read -r u b; do
    [[ -n "$u" ]] || continue
    if [[ -n "$user" && "$u" != "$user" ]]; then
      continue
    fi
    total=$((total + b))
    printf "%-22s %-14s %-12s\n" "$u" "$b" "$(bytes_to_human "$b")"
  done <<< "$rows"

  echo
  printf "%-22s %-14s %-12s\n" "TOTAL" "$total" "$(bytes_to_human "$total")"
}

quota_file_ensure() {
  mkdir -p "$(dirname "$PROXYCTL_QUOTA_FILE")"
  touch "$PROXYCTL_QUOTA_FILE"
}

quota_set() {
  need_root
  [[ $# -eq 2 ]] || err "usage: proxyctl quota set <username> <GB>"
  local user="$1"
  local gb="$2"
  require_user "$user"
  [[ "$gb" =~ ^[0-9]+([.][0-9]+)?$ ]] || err "GB must be numeric"
  quota_file_ensure

  local tmp
  tmp="$(mktemp)"
  awk -F= -v u="$user" '$1!=u && NF>=2 {print $0}' "$PROXYCTL_QUOTA_FILE" > "$tmp"
  echo "${user}=${gb}" >> "$tmp"
  sort -u "$tmp" > "$PROXYCTL_QUOTA_FILE"
  rm -f "$tmp"
  echo "quota set: $user = ${gb} GB"
}

quota_del() {
  need_root
  [[ $# -eq 1 ]] || err "usage: proxyctl quota del <username>"
  local user="$1"
  quota_file_ensure
  local tmp
  tmp="$(mktemp)"
  awk -F= -v u="$user" '$1!=u && NF>=2 {print $0}' "$PROXYCTL_QUOTA_FILE" > "$tmp"
  mv "$tmp" "$PROXYCTL_QUOTA_FILE"
  echo "quota removed: $user"
}

quota_list() {
  need_root
  local since
  since="$(month_start_utc)"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --since)
        shift
        [[ $# -gt 0 ]] || err "--since requires a value"
        since="$1"
        ;;
      -h|--help)
        print_quota_help
        return
        ;;
      *)
        err "unknown option: $1"
        ;;
    esac
    shift
  done
  quota_file_ensure
  local rows
  rows="$(usage_rows "$since" || true)"

  echo "[quota]"
  echo "since: $since"
  echo "file: $PROXYCTL_QUOTA_FILE"
  echo
  printf "%-22s %-10s %-14s %-12s %-8s\n" "user" "limit(GB)" "used(bytes)" "used(human)" "status"
  printf "%-22s %-10s %-14s %-12s %-8s\n" "----------------------" "----------" "--------------" "------------" "--------"

  while IFS='=' read -r u g; do
    [[ -n "$u" && -n "$g" ]] || continue
    local used=0 lim
    used="$(awk -v usr="$u" '$1==usr {print $2}' <<< "$rows" | head -n1)"
    [[ -n "$used" ]] || used=0
    lim="$(gb_to_bytes "$g")"
    local st="ok"
    if (( used > lim )); then st="over"; fi
    printf "%-22s %-10s %-14s %-12s %-8s\n" "$u" "$g" "$used" "$(bytes_to_human "$used")" "$st"
  done < "$PROXYCTL_QUOTA_FILE"
}

quota_enforce() {
  need_root
  local since dry
  since="$(month_start_utc)"
  dry="false"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --since)
        shift
        [[ $# -gt 0 ]] || err "--since requires a value"
        since="$1"
        ;;
      --dry-run) dry="true" ;;
      -h|--help)
        print_quota_help
        return
        ;;
      *)
        err "unknown option: $1"
        ;;
    esac
    shift
  done
  quota_file_ensure
  local rows
  rows="$(usage_rows "$since" || true)"

  echo "[quota-enforce]"
  echo "since: $since"
  echo "dry_run: $dry"

  while IFS='=' read -r u g; do
    [[ -n "$u" && -n "$g" ]] || continue
    if ! id "$u" >/dev/null 2>&1; then
      echo "skip: $u (user not found)"
      continue
    fi
    local used=0 lim state
    used="$(awk -v usr="$u" '$1==usr {print $2}' <<< "$rows" | head -n1)"
    [[ -n "$used" ]] || used=0
    lim="$(gb_to_bytes "$g")"
    state="$(passwd -S "$u" | awk '{print $2}')"

    if (( used > lim )); then
      if [[ "$state" == "L" ]]; then
        echo "locked: $u (already locked, used=$(bytes_to_human "$used"), limit=${g}GB)"
      else
        if [[ "$dry" == "true" ]]; then
          echo "would lock: $u (used=$(bytes_to_human "$used"), limit=${g}GB)"
        else
          passwd -l "$u" >/dev/null
          echo "locked: $u (used=$(bytes_to_human "$used"), limit=${g}GB)"
        fi
      fi
    else
      echo "ok: $u (used=$(bytes_to_human "$used"), limit=${g}GB)"
    fi
  done < "$PROXYCTL_QUOTA_FILE"
}

set_password() {
  local user="$1"
  shift
  local mode="random"
  local pass=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --password)
        shift
        [[ $# -gt 0 ]] || err "--password requires a value"
        mode="manual"
        pass="$1"
        ;;
      --random)
        mode="random"
        ;;
      *)
        err "unknown option: $1"
        ;;
    esac
    shift
  done

  if [[ "$mode" == "random" ]]; then
    pass="$(random_password)"
  fi

  echo "${user}:${pass}" | chpasswd
  echo "username: ${user}"
  echo "password: ${pass}"
}

bootstrap_user_ensure() {
  local user="$1"
  local password="$2"
  local reset_existing="$3"
  local fmt="$4"
  local host port
  host="$(proxy_host || true)"
  [[ -n "$host" ]] || host="unknown"
  port="$(proxy_port)"
  ensure_group

  if id "$user" >/dev/null 2>&1; then
    usermod -aG "$PROXY_GROUP" "$user"
    if [[ "$reset_existing" == "true" ]]; then
      [[ -n "$password" ]] || password="$(random_password)"
      echo "${user}:${password}" | chpasswd
      print_access_data "$user" "$password" "$host" "$port" "$fmt"
    else
      echo "user exists: $user"
    fi
    return
  fi

  [[ -n "$password" ]] || password="$(random_password)"
  useradd -M -s /usr/sbin/nologin -G "$PROXY_GROUP" "$user"
  echo "${user}:${password}" | chpasswd
  print_access_data "$user" "$password" "$host" "$port" "$fmt"
}

bootstrap_configure_ufw() {
  local port="$1"
  local udp_range="$2"
  shift 2
  local ufw_udp_range cidr
  local -a allow_ips=( "$@" )
  ufw_udp_range="${udp_range/-/:}"

  if (( ${#allow_ips[@]} > 0 )); then
    for cidr in "${allow_ips[@]}"; do
      ufw allow from "$cidr" to any port "$port" proto tcp >/dev/null || true
      ufw allow from "$cidr" to any port "$ufw_udp_range" proto udp >/dev/null || true
      echo "ufw allow: $cidr -> tcp/$port udp/$ufw_udp_range"
    done
  else
    ufw allow "$port"/tcp >/dev/null || true
    ufw allow "$ufw_udp_range"/udp >/dev/null || true
    echo "ufw allow: public tcp/$port udp/$ufw_udp_range"
  fi
}

bootstrap() {
  need_root
  local iface="" port="1080" udp_range="20000-20100"
  local proxy_user="proxy-user" proxy_password="" reset_password="false"
  local fmt="generic" skip_fail2ban="false" skip_ufw="false" dry_run="false"
  local -a allow_ips=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --iface)
        shift
        [[ $# -gt 0 ]] || err "--iface requires a value"
        iface="$1"
        ;;
      --port)
        shift
        [[ $# -gt 0 ]] || err "--port requires a value"
        port="$1"
        ;;
      --udp-range)
        shift
        [[ $# -gt 0 ]] || err "--udp-range requires a value"
        udp_range="$1"
        ;;
      --proxy-user)
        shift
        [[ $# -gt 0 ]] || err "--proxy-user requires a value"
        proxy_user="$1"
        ;;
      --proxy-password)
        shift
        [[ $# -gt 0 ]] || err "--proxy-password requires a value"
        proxy_password="$1"
        reset_password="true"
        ;;
      --proxy-password-random)
        proxy_password="$(random_password)"
        reset_password="true"
        ;;
      --reset-password)
        reset_password="true"
        ;;
      --format)
        shift
        [[ $# -gt 0 ]] || err "--format requires a value"
        fmt="$1"
        ;;
      --allow-ip)
        shift
        [[ $# -gt 0 ]] || err "--allow-ip requires a value"
        allow_ips+=( "$1" )
        ;;
      --public)
        ;;
      --skip-fail2ban)
        skip_fail2ban="true"
        ;;
      --skip-ufw)
        skip_ufw="true"
        ;;
      --dry-run)
        dry_run="true"
        ;;
      help|-h|--help)
        print_bootstrap_help
        return
        ;;
      *)
        err "unknown option: $1"
        ;;
    esac
    shift
  done

  [[ -n "$iface" ]] || iface="$(default_iface)"
  [[ -n "$iface" ]] || err "could not detect interface; use --iface"
  username_ok "$proxy_user" || err "invalid username format: $proxy_user"
  port_ok "$port" || err "invalid port: $port"
  [[ "$udp_range" =~ ^[0-9]+-[0-9]+$ ]] || err "invalid udp range: $udp_range"
  [[ "$fmt" == "generic" || "$fmt" == "telegram" || "$fmt" == "uri" ]] || err "invalid format: $fmt"

  echo "[bootstrap]"
  echo "iface: $iface"
  echo "port: $port"
  echo "udp_range: $udp_range"
  echo "proxy_user: $proxy_user"
  echo "fail2ban: $([[ "$skip_fail2ban" == "true" ]] && echo disabled || echo enabled)"
  echo "ufw: $([[ "$skip_ufw" == "true" ]] && echo skipped || echo managed)"
  if (( ${#allow_ips[@]} > 0 )); then
    echo "allow_ips: ${allow_ips[*]}"
  else
    echo "allow_ips: public"
  fi
  echo "dry_run: $dry_run"

  if [[ "$dry_run" == "true" ]]; then
    echo "would run: apt-get update"
    if [[ "$skip_fail2ban" == "true" ]]; then
      echo "would run: apt-get install -y dante-server ufw"
    else
      echo "would run: apt-get install -y dante-server ufw fail2ban"
    fi
    echo "would write: $DANTED_CONF"
    echo "would write: $PAM_DANTED_FILE"
    if [[ "$skip_fail2ban" != "true" ]]; then
      echo "would write: $FAIL2BAN_DANTED_FILTER"
      echo "would write: $FAIL2BAN_DANTED_JAIL"
    fi
    if [[ "$skip_ufw" != "true" ]]; then
      if (( ${#allow_ips[@]} > 0 )); then
        echo "would manage ufw for: ${allow_ips[*]}"
      else
        echo "would manage ufw for: public"
      fi
    fi
    echo "would ensure proxy user: $proxy_user"
    return
  fi

  apt-get update
  if [[ "$skip_fail2ban" == "true" ]]; then
    apt-get install -y dante-server ufw
  else
    apt-get install -y dante-server ufw fail2ban
  fi

  ensure_runtime_dirs
  ensure_group
  write_managed_file "$DANTED_CONF" "$(render_bootstrap_danted_conf "$iface" "$port" "$udp_range")"
  write_managed_file "$PAM_DANTED_FILE" "$(render_bootstrap_pam_danted)"
  if [[ "$skip_fail2ban" != "true" ]]; then
    write_managed_file "$FAIL2BAN_DANTED_FILTER" "$(render_bootstrap_fail2ban_filter)"
    write_managed_file "$FAIL2BAN_DANTED_JAIL" "$(render_bootstrap_fail2ban_jail "$port")"
  fi

  systemctl daemon-reload
  systemctl enable danted
  systemctl restart danted
  if [[ "$skip_fail2ban" != "true" ]]; then
    systemctl enable fail2ban
    systemctl restart fail2ban
  fi

  bootstrap_user_ensure "$proxy_user" "$proxy_password" "$reset_password" "$fmt"

  if [[ "$skip_ufw" != "true" ]]; then
    bootstrap_configure_ufw "$port" "$udp_range" "${allow_ips[@]}"
  fi

  echo
  doctor
}

service_status() {
  need_root
  systemctl --no-pager --full status "$DANTED_SERVICE"
}

service_restart() {
  need_root
  systemctl restart "$DANTED_SERVICE"
  systemctl --no-pager --full status "$DANTED_SERVICE" | sed -n '1,12p'
}

service_logs() {
  need_root
  local since=""
  local follow="false"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --since)
        shift
        [[ $# -gt 0 ]] || err "--since requires a value"
        since="$1"
        ;;
      --follow)
        follow="true"
        ;;
      -h|--help)
        print_service_help
        return
        ;;
      *)
        err "unknown option: $1"
        ;;
    esac
    shift
  done

  local -a args=( -u "$DANTED_SERVICE" )
  [[ -n "$since" ]] && args+=( --since "$since" )
  if [[ "$follow" == "true" ]]; then
    args+=( -f )
  else
    args+=( -n 100 )
  fi
  journalctl "${args[@]}"
}

service_connections() {
  need_root
  ss -tnp | awk 'NR==1 || /danted/'
}

user_list() {
  need_root
  ensure_group
  local members
  members="$(getent group "$PROXY_GROUP" | awk -F: '{print $4}')"
  if [[ -z "$members" ]]; then
    echo "No managed proxy users in group '$PROXY_GROUP'."
    return
  fi

  IFS=',' read -r -a arr <<< "$members"
  for u in "${arr[@]}"; do
    if id "$u" >/dev/null 2>&1; then
      local state
      state="$(passwd -S "$u" | awk '{print $2}')"
      echo "$u (passwd_state=$state)"
    fi
  done
}

user_adopt() {
  need_root
  [[ $# -eq 1 ]] || err "usage: proxyctl user adopt <username>"
  local user="$1"
  require_user "$user"
  ensure_group
  usermod -aG "$PROXY_GROUP" "$user"
  echo "user '$user' added to group '$PROXY_GROUP'"
}

user_add() {
  need_root
  [[ $# -ge 1 ]] || err "usage: proxyctl user add <username> [--password <pass> | --random] [--format generic|telegram|uri]"
  local user="$1"
  shift
  local mode="random"
  local pass=""
  local fmt="generic"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --password)
        shift
        [[ $# -gt 0 ]] || err "--password requires a value"
        mode="manual"
        pass="$1"
        ;;
      --random)
        mode="random"
        ;;
      --format)
        shift
        [[ $# -gt 0 ]] || err "--format requires a value"
        fmt="$1"
        ;;
      *)
        err "unknown option: $1"
        ;;
    esac
    shift
  done

  username_ok "$user" || err "invalid username format: $user"
  if id "$user" >/dev/null 2>&1; then
    err "user '$user' already exists"
  fi

  if [[ "$mode" == "random" ]]; then
    pass="$(random_password)"
  fi

  ensure_group
  useradd -M -s /usr/sbin/nologin -G "$PROXY_GROUP" "$user"
  echo "${user}:${pass}" | chpasswd

  local host
  host="$(proxy_host || true)"
  [[ -n "$host" ]] || host="unknown"
  print_access_data "$user" "$pass" "$host" "$(proxy_port)" "$fmt"
}

user_passwd() {
  need_root
  [[ $# -ge 1 ]] || err "usage: proxyctl user passwd <username> [--password <pass> | --random]"
  local user="$1"
  shift
  require_user "$user"
  set_password "$user" "$@"
}

user_access() {
  need_root
  [[ $# -ge 1 ]] || err "usage: proxyctl user access <username> [--reset-password] [--format generic|telegram|uri]"
  local user="$1"
  shift
  require_user "$user"

  local reset="false"
  local fmt="generic"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --reset-password) reset="true" ;;
      --format)
        shift
        [[ $# -gt 0 ]] || err "--format requires a value"
        fmt="$1"
        ;;
      *) err "unknown option: $1" ;;
    esac
    shift
  done

  local host port pass
  host="$(proxy_host || true)"
  [[ -n "$host" ]] || host="unknown"
  port="$(proxy_port)"

  if [[ "$reset" == "true" ]]; then
    pass="$(random_password)"
    echo "${user}:${pass}" | chpasswd
  else
    pass="$(t password_unknown)"
  fi

  print_access_data "$user" "$pass" "$host" "$port" "$fmt"
}

user_lock() {
  need_root
  [[ $# -eq 1 ]] || err "usage: proxyctl user lock <username>"
  require_user "$1"
  passwd -l "$1"
}

user_unlock() {
  need_root
  [[ $# -eq 1 ]] || err "usage: proxyctl user unlock <username>"
  require_user "$1"
  passwd -u "$1"
}

user_delete() {
  need_root
  [[ $# -eq 1 ]] || err "usage: proxyctl user delete <username>"
  require_user "$1"
  userdel "$1"
}

firewall_status() {
  need_root
  ufw status verbose
}

firewall_allow_ip() {
  need_root
  [[ $# -ge 1 ]] || err "usage: proxyctl firewall allow-ip <ip-or-cidr> [--port <port>]"
  local ip="$1"
  shift
  local port
  port="$(proxy_port)"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --port)
        shift
        [[ $# -gt 0 ]] || err "--port requires a value"
        port="$1"
        ;;
      *)
        err "unknown option: $1"
        ;;
    esac
    shift
  done

  port_ok "$port" || err "invalid port: $port"
  ufw allow from "$ip" to any port "$port" proto tcp
}

firewall_revoke_ip() {
  need_root
  [[ $# -ge 1 ]] || err "usage: proxyctl firewall revoke-ip <ip-or-cidr> [--port <port>]"
  local ip="$1"
  shift
  local port
  port="$(proxy_port)"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --port)
        shift
        [[ $# -gt 0 ]] || err "--port requires a value"
        port="$1"
        ;;
      *)
        err "unknown option: $1"
        ;;
    esac
    shift
  done

  port_ok "$port" || err "invalid port: $port"
  ufw delete allow from "$ip" to any port "$port" proto tcp
}

firewall_open_public() {
  need_root
  local port="$(proxy_port)"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --port)
        shift
        [[ $# -gt 0 ]] || err "--port requires a value"
        port="$1"
        ;;
      *)
        err "unknown option: $1"
        ;;
    esac
    shift
  done

  port_ok "$port" || err "invalid port: $port"
  ufw allow "$port"/tcp
}

firewall_close_public() {
  need_root
  local port="$(proxy_port)"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --port)
        shift
        [[ $# -gt 0 ]] || err "--port requires a value"
        port="$1"
        ;;
      *)
        err "unknown option: $1"
        ;;
    esac
    shift
  done

  port_ok "$port" || err "invalid port: $port"
  ufw delete allow "$port"/tcp
}

config_show() {
  need_root
  cat "$DANTED_CONF"
}

config_port() {
  need_root
  if [[ $# -eq 0 ]]; then
    echo "$(proxy_port)"
    return
  fi

  [[ $# -eq 1 ]] || err "usage: proxyctl config port [<new-port>]"
  local new_port="$1"
  port_ok "$new_port" || err "invalid port: $new_port"

  local ts backup
  ts="$(date +%F-%H%M%S)"
  backup="${DANTED_CONF}.bak.${ts}"
  cp "$DANTED_CONF" "$backup"

  sed -i -E "s|^(internal:[[:space:]]+[^[:space:]]+[[:space:]]+port[[:space:]]*=[[:space:]]*)[0-9]+|\\1${new_port}|" "$DANTED_CONF"
  echo "backup: $backup"
  echo "new_port: $new_port"
  echo "Run: sudo proxyctl service restart"
}

config_backup() {
  need_root
  local ts backup
  ts="$(date +%F-%H%M%S)"
  backup="${DANTED_CONF}.bak.${ts}"
  cp "$DANTED_CONF" "$backup"
  echo "$backup"
}

config_restore() {
  need_root
  [[ $# -eq 1 ]] || err "usage: proxyctl config restore <backup-file>"
  local file="$1"
  [[ -f "$file" ]] || err "backup file not found: $file"
  cp "$file" "$DANTED_CONF"
  echo "restored from: $file"
  echo "Run: sudo proxyctl service restart"
}

lang_show() {
  load_lang
  echo "$LANG_CODE"
}

lang_set() {
  need_root
  [[ $# -eq 1 ]] || err "usage: proxyctl lang set <en|ru>"
  save_lang "$1"
  echo "$(t lang_changed): $LANG_CODE"
}

audit() {
  need_root
  local since="24 hours ago"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --since)
        shift
        [[ $# -gt 0 ]] || err "--since requires a value"
        since="$1"
        ;;
      -h|--help)
        print_audit_help
        return
        ;;
      *)
        err "unknown option: $1"
        ;;
    esac
    shift
  done

  echo "[audit]"
  echo "window: $since"

  local auth_tmp danted_tmp
  auth_tmp="$(mktemp)"
  danted_tmp="$(mktemp)"
  trap 'rm -f "${auth_tmp:-}" "${danted_tmp:-}"' RETURN

  journalctl --since "$since" --grep 'pam_unix\(danted:auth\): authentication failure' --no-pager > "$auth_tmp" 2>/dev/null || true
  journalctl -u "$DANTED_SERVICE" --since "$since" --grep 'username%[^@]+@|block\([0-9]+\): tcp/accept .*no rules matched' --no-pager > "$danted_tmp" 2>/dev/null || true

  local fail_count
  fail_count="$(sed '/^$/d' "$auth_tmp" | wc -l)"
  if [[ ! -s "$auth_tmp" ]]; then
    fail_count=0
  fi

  echo
  echo "[auth_failures]"
  echo "count: $fail_count"
  if [[ "$fail_count" -gt 0 ]]; then
    echo "top_source_ips:"
    sed -n 's/.*rhost=\([^ ]*\).*/\1/p' "$auth_tmp" \
      | sed '/^$/d' \
      | awk '{c[$1]++} END {for (ip in c) printf "%7d %s\n", c[ip], ip}' \
      | sort -nr | head -n 10
  fi

  echo
  echo "[top_users_success]"
  if ! grep -q 'username%' "$danted_tmp"; then
    echo "no data"
  else
    sed -n 's/.*username%\([^@ ]*\)@.*/\1/p' "$danted_tmp" \
      | sed '/^$/d' \
      | awk '{c[$1]++} END {for (user in c) printf "%7d %s\n", c[user], user}' \
      | sort -nr | head -n 10
  fi

  echo
  echo "[top_source_ips_success]"
  if ! grep -q 'username%' "$danted_tmp"; then
    echo "no data"
  else
    sed -n 's/.*username%[^@]*@\([0-9.]*\)\.[0-9][0-9]* .*/\1/p' "$danted_tmp" \
      | sed '/^$/d' \
      | awk '{c[$1]++} END {for (ip in c) printf "%7d %s\n", c[ip], ip}' \
      | sort -nr | head -n 10
  fi

  local blocked_count
  blocked_count="$(grep -Ec 'block\([0-9]+\): tcp/accept .*no rules matched' "$danted_tmp" || true)"
  echo
  echo "[blocked_by_rules]"
  echo "count: $blocked_count"
  if [[ "$blocked_count" -gt 0 ]]; then
    echo "top_source_ips:"
    perl -ne 'print "$1\n" if /: ([0-9]+(?:\.[0-9]+){3})\.[0-9]+ [0-9]+(?:\.[0-9]+){3}\.[0-9]+: blocked/' "$danted_tmp" \
      | sed '/^$/d' \
      | awk '{c[$1]++} END {for (ip in c) printf "%7d %s\n", c[ip], ip}' \
      | sort -nr | head -n 10
  fi

  echo
  echo "[fail2ban]"
  if systemctl is-active --quiet fail2ban; then
    echo "status: active"
    fail2ban-client status danted-auth 2>/dev/null || echo "jail danted-auth not enabled"
  else
    echo "status: inactive"
  fi
}

doctor() {
  need_root
  local port iface udp_range udp_enabled
  port="$(proxy_port)"
  iface="$(proxy_internal_iface)"
  udp_range="$(sed -n 's/^[[:space:]]*udp\.portrange:[[:space:]]*\([0-9-]\+\).*/\1/p' "$DANTED_CONF" | head -n1)"
  udp_enabled="no"
  if grep -Eq '^[[:space:]]*command:.*udpassociate' "$DANTED_CONF"; then
    udp_enabled="yes"
  fi

  echo "[service]"
  if systemctl is-active --quiet "$DANTED_SERVICE"; then
    echo "ok: danted is active"
  else
    echo "fail: danted is not active"
  fi

  echo
  echo "[listen]"
  if ss -ltnp | grep -q ":${port}[[:space:]]"; then
    echo "ok: danted listens on port ${port}"
    ss -ltnp | awk 'NR==1 {print; next} $0 ~ ":"p"[[:space:]]" {print}' p="$port"
  else
    echo "fail: nothing listens on port ${port}"
  fi

  echo
  echo "[config]"
  echo "internal_iface: ${iface}"
  echo "port: ${port}"
  echo "udp_associate: ${udp_enabled}"
  echo "udp_portrange: ${udp_range:-not set}"

  echo
  echo "[users]"
  user_list || true

  echo
  echo "[udp]"
  if [[ "$udp_enabled" == "yes" ]]; then
    echo "ok: udpassociate enabled"
  else
    echo "fail: udpassociate not enabled"
  fi
  if [[ -n "$udp_range" ]]; then
    local ufw_udp_range
    ufw_udp_range="${udp_range/-/:}"
    echo "configured_range: $udp_range"
    if ufw status | grep -q "$ufw_udp_range/udp"; then
      echo "ok: ufw allows $ufw_udp_range/udp"
    else
      echo "fail: ufw missing $ufw_udp_range/udp"
    fi
  else
    echo "warn: udp.portrange not configured"
  fi

  echo
  echo "[ufw]"
  ufw status | sed -n '1,25p'
}

# Legacy aliases for backward compatibility
legacy_alias() {
  local cmd="$1"
  shift || true

  case "$cmd" in
    status) service_status "$@" ;;
    restart) service_restart "$@" ;;
    logs) service_logs "$@" ;;
    connections) service_connections "$@" ;;
    show-config) config_show "$@" ;;
    ufw-status) firewall_status "$@" ;;

    list-users) user_list "$@" ;;
    adopt-user) user_adopt "$@" ;;
    add-user) user_add "$@" ;;
    set-password) user_passwd "$@" ;;
    access) user_access "$@" ;;
    lock) user_lock "$@" ;;
    unlock) user_unlock "$@" ;;
    del-user) user_delete "$@" ;;

    allow-ip) firewall_allow_ip "$@" ;;
    revoke-ip) firewall_revoke_ip "$@" ;;
    audit)
      if [[ "${1:-}" == "help" || "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
        print_audit_help
      else
        audit "$@"
      fi
      ;;
    usage)
      if [[ "${1:-}" == "help" || "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
        print_usage_help
      else
        usage "$@"
      fi
      ;;
    *) return 1 ;;
  esac
  return 0
}

prompt_nonempty() {
  local label="$1"
  local val=""
  while true; do
    read -r -p "$label: " val
    [[ -n "$val" ]] && break
  done
  echo "$val"
}

safe_call() {
  if ! ( "$@" ); then
    true
  fi
}

interactive_user_menu() {
  while true; do
    clear
    ui_header "$(t user_menu)"
    ui_statusbar
    ui_section_spacer
    ui_menu_item 1 "$(t list_users)"
    ui_menu_item 2 "$(t add_user)"
    ui_menu_item 3 "$(t adopt_user)"
    ui_menu_item 4 "$(t change_password)"
    ui_menu_item 5 "$(t lock_user)"
    ui_menu_item 6 "$(t unlock_user)"
    ui_menu_item 7 "$(t delete_user)"
    ui_menu_item 8 "$(t access_data)"
    ui_hotkeys_hint
    ui_prompt "$(t select)"
    choice="$REPLY"
    case "$choice" in
      h|H) run_action print_user_help ;;
      b|B) return ;;
      q|Q) echo "$(t bye)"; exit 0 ;;
      1) run_action user_list ;;
      2)
        local u mode p fmt
        u="$(prompt_nonempty "$(t username)")"
        read -r -p "$(t random_password_q): " mode
        read -r -p "$(t format_prompt): " fmt
        fmt="${fmt:-generic}"
        if [[ "${mode:-Y}" =~ ^[Nn]$ ]]; then
          p="$(prompt_nonempty "$(t password)")"
          run_action user_add "$u" --password "$p" --format "$fmt"
        else
          run_action user_add "$u" --random --format "$fmt"
        fi
        ;;
      3)
        local u
        u="$(prompt_nonempty "$(t existing_username)")"
        run_action user_adopt "$u"
        ;;
      4)
        local u mode p
        u="$(prompt_nonempty "$(t username)")"
        read -r -p "$(t random_password_q): " mode
        if [[ "${mode:-Y}" =~ ^[Nn]$ ]]; then
          p="$(prompt_nonempty "$(t new_password)")"
          run_action user_passwd "$u" --password "$p"
        else
          run_action user_passwd "$u" --random
        fi
        ;;
      5)
        local u
        u="$(prompt_nonempty "$(t username)")"
        run_action user_lock "$u"
        ;;
      6)
        local u
        u="$(prompt_nonempty "$(t username)")"
        run_action user_unlock "$u"
        ;;
      7)
        local u confirm
        u="$(prompt_nonempty "$(t username)")"
        read -r -p "$(printf "$(t delete_confirm)" "$u"): " confirm
        [[ "$confirm" == "YES" ]] || { ui_note "$(t cancelled)"; ui_pause; continue; }
        run_action user_delete "$u"
        ;;
      8)
        local u reset fmt
        u="$(prompt_nonempty "$(t username)")"
        read -r -p "$(t reset_password_q): " reset
        read -r -p "$(t format_prompt): " fmt
        fmt="${fmt:-generic}"
        if [[ "${reset:-Y}" =~ ^[Nn]$ ]]; then
          run_action user_access "$u" --format "$fmt"
        else
          run_action user_access "$u" --reset-password --format "$fmt"
        fi
        ;;
      0) return ;;
      *) ui_note "$(t invalid)"; ui_pause ;;
    esac
  done
}

interactive_firewall_menu() {
  while true; do
    clear
    ui_header "$(t firewall_menu)"
    ui_statusbar
    ui_section_spacer
    ui_menu_item 1 "$(t ufw_status)"
    ui_menu_item 2 "$(t allow_ip)"
    ui_menu_item 3 "$(t revoke_ip)"
    ui_menu_item 4 "$(t open_public)"
    ui_menu_item 5 "$(t close_public)"
    ui_hotkeys_hint
    ui_prompt "$(t select)"
    choice="$REPLY"
    case "$choice" in
      h|H) run_action print_firewall_help ;;
      b|B) return ;;
      q|Q) echo "$(t bye)"; exit 0 ;;
      1) run_action firewall_status ;;
      2)
        local ip
        ip="$(prompt_nonempty "$(t ip_cidr)")"
        run_action firewall_allow_ip "$ip"
        ;;
      3)
        local ip
        ip="$(prompt_nonempty "$(t ip_cidr)")"
        run_action firewall_revoke_ip "$ip"
        ;;
      4)
        local c
        read -r -p "$(t open_confirm): " c
        [[ "$c" == "OPEN" ]] || { ui_note "$(t cancelled)"; ui_pause; continue; }
        run_action firewall_open_public
        ;;
      5) run_action firewall_close_public ;;
      0) return ;;
      *) ui_note "$(t invalid)"; ui_pause ;;
    esac
  done
}

interactive_config_menu() {
  while true; do
    clear
    ui_header "$(t config_menu)"
    ui_statusbar
    ui_section_spacer
    ui_menu_item 1 "$(t show_config)"
    ui_menu_item 2 "$(t show_port)"
    ui_menu_item 3 "$(t change_port)"
    ui_menu_item 4 "$(t backup_config)"
    ui_menu_item 5 "$(t restore_config)"
    ui_hotkeys_hint
    ui_prompt "$(t select)"
    choice="$REPLY"
    case "$choice" in
      h|H) run_action print_config_help ;;
      b|B) return ;;
      q|Q) echo "$(t bye)"; exit 0 ;;
      1) run_action config_show ;;
      2) run_action config_port ;;
      3)
        local p
        p="$(prompt_nonempty "$(t new_port)")"
        run_action config_port "$p"
        ;;
      4) run_action config_backup ;;
      5)
        local f
        f="$(prompt_nonempty "$(t backup_path)")"
        run_action config_restore "$f"
        ;;
      0) return ;;
      *) ui_note "$(t invalid)"; ui_pause ;;
    esac
  done
}

interactive_main() {
  need_root
  while true; do
    clear
    ui_header "$(t main_menu)"
    ui_statusbar
    ui_section_spacer
    ui_menu_item 1 "$(t health_check)"
    ui_menu_item 2 "$(t service_status)"
    ui_menu_item 3 "$(t service_restart)"
    ui_menu_item 4 "$(t live_logs)"
    ui_menu_item 5 "$(t active_connections)"
    ui_menu_item 6 "$(t user_management)"
    ui_menu_item 7 "$(t firewall_management)"
    ui_menu_item 8 "$(t config_management)"
    ui_menu_item 9 "$(t help)"
    ui_menu_item 10 "$(t language)"
    ui_menu_item 11 "$(t audit)"
    ui_menu_item 12 "$(t usage)"
    ui_menu_item 13 "$(t quota)"
    ui_hotkeys_hint
    ui_prompt "$(t select)"
    choice="$REPLY"
    case "$choice" in
      h|H) print_main_help; ui_pause ;;
      q|Q) echo "$(t bye)"; return ;;
      1) run_action doctor ;;
      2) run_action service_status ;;
      3) run_action service_restart ;;
      4) run_action service_logs --follow ;;
      5) run_action service_connections ;;
      6) interactive_user_menu ;;
      7) interactive_firewall_menu ;;
      8) interactive_config_menu ;;
      9) print_main_help; ui_pause ;;
      10)
        echo "$(t lang_now): $(lang_show)"
        local l
        read -r -p "$(t lang_set_prompt): " l
        if [[ "$l" == "ru" || "$l" == "en" ]]; then
          save_lang "$l"
          echo "$(t lang_changed): $LANG_CODE"
        else
          echo "$(t invalid)"
        fi
        ui_pause
        ;;
      11) run_action audit ;;
      12) run_action usage ;;
      13) run_action quota_list ;;
      0) echo "$(t bye)"; return ;;
      *) ui_note "$(t invalid)"; ui_pause ;;
    esac
  done
}

main() {
  ui_init
  load_lang

  if [[ $# -eq 0 ]]; then
    if [[ -t 0 && -t 1 ]]; then
      interactive_main
    else
      print_main_help
    fi
    return
  fi

  local group="$1"
  shift

  if legacy_alias "$group" "$@"; then
    return
  fi

  case "$group" in
    help|-h|--help)
      print_main_help
      ;;

    bootstrap)
      if [[ "${1:-}" == "help" || "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
        print_bootstrap_help
      else
        bootstrap "$@"
      fi
      ;;

    service)
      local cmd="${1:-help}"
      shift || true
      case "$cmd" in
        help|-h|--help) print_service_help ;;
        status) service_status "$@" ;;
        restart) service_restart "$@" ;;
        logs) service_logs "$@" ;;
        connections) service_connections "$@" ;;
        *) err "unknown service command: $cmd" ;;
      esac
      ;;

    user)
      local cmd="${1:-help}"
      shift || true
      case "$cmd" in
        help|-h|--help) print_user_help ;;
        list) user_list "$@" ;;
        adopt) user_adopt "$@" ;;
        add) user_add "$@" ;;
        passwd) user_passwd "$@" ;;
        access) user_access "$@" ;;
        lock) user_lock "$@" ;;
        unlock) user_unlock "$@" ;;
        delete) user_delete "$@" ;;
        *) err "unknown user command: $cmd" ;;
      esac
      ;;

    firewall)
      local cmd="${1:-help}"
      shift || true
      case "$cmd" in
        help|-h|--help) print_firewall_help ;;
        status) firewall_status "$@" ;;
        allow-ip) firewall_allow_ip "$@" ;;
        revoke-ip) firewall_revoke_ip "$@" ;;
        open-public) firewall_open_public "$@" ;;
        close-public) firewall_close_public "$@" ;;
        *) err "unknown firewall command: $cmd" ;;
      esac
      ;;

    config)
      local cmd="${1:-help}"
      shift || true
      case "$cmd" in
        help|-h|--help) print_config_help ;;
        show) config_show "$@" ;;
        port) config_port "$@" ;;
        backup) config_backup "$@" ;;
        restore) config_restore "$@" ;;
        *) err "unknown config command: $cmd" ;;
      esac
      ;;

    lang)
      local cmd="${1:-help}"
      shift || true
      case "$cmd" in
        help|-h|--help) print_lang_help ;;
        show) lang_show "$@" ;;
        set) lang_set "$@" ;;
        *) err "unknown lang command: $cmd" ;;
      esac
      ;;

    audit)
      if [[ "${1:-}" == "help" || "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
        print_audit_help
      else
        audit "$@"
      fi
      ;;

    usage)
      if [[ "${1:-}" == "help" || "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
        print_usage_help
      else
        usage "$@"
      fi
      ;;

    quota)
      local cmd="${1:-help}"
      shift || true
      case "$cmd" in
        help|-h|--help) print_quota_help ;;
        list) quota_list "$@" ;;
        set) quota_set "$@" ;;
        del|delete|rm) quota_del "$@" ;;
        enforce) quota_enforce "$@" ;;
        *) err "unknown quota command: $cmd" ;;
      esac
      ;;

    doctor)
      doctor "$@"
      ;;

    *)
      err "unknown command group: $group (run: proxyctl help)"
      ;;
  esac
}

main "$@"
