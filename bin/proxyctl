    continue_prompt) echo "Press Enter to continue..." ;;
    hotkeys_hint) echo "Hotkeys: h=help, b=back, q=quit" ;;
    *) echo "$key" ;;
  esac
}

ui_init() {
  ui_width_init
  if [[ "${NO_COLOR:-}" != "" ]]; then
    UI_COLOR=0
  fi
  if [[ ! -t 1 ]]; then
    UI_COLOR=0
  fi
  if [[ "$UI_COLOR" -eq 1 ]]; then
    CLR_RESET=$'\033[0m'
    CLR_TITLE=$'\033[1;36m'
    CLR_ACCENT=$'\033[1;34m'
    CLR_OK=$'\033[1;32m'
    CLR_WARN=$'\033[1;33m'
    CLR_ERR=$'\033[1;31m'
  fi
}

ui_color() {
  local c="$1"
  shift
  if [[ "$UI_COLOR" -eq 1 ]]; then
    printf "%b%s%b" "$c" "$*" "$CLR_RESET"
  else
    printf "%s" "$*"
  fi
}

ui_hr() {
  printf '%*s\n' "$UI_WIDTH" '' | tr ' ' '-'
}

ui_width_init() {
  local w="${COLUMNS:-88}"
  if ! [[ "$w" =~ ^[0-9]+$ ]]; then
    w=88
  fi
  if (( w < 72 )); then
    w=72
  fi
  if (( w > 104 )); then
    w=104
  fi
  UI_WIDTH="$w"
}

ui_block_line() {
  local text="$1"
  local max=$((UI_WIDTH - 4))
  if ((${#text} > max)); then
    text="${text:0:max}"
  fi
  printf "| %-*s |\n" "$max" "$text"
}

ui_box_open() {
  printf "+%s+\n" "$(printf '%*s' "$((UI_WIDTH - 2))" '' | tr ' ' '-')"
}

ui_box_close() {
  ui_box_open
}

ui_header() {
  local title="$1"
  echo
  ui_box_open
  ui_block_line "proxyctl"
  ui_block_line "$title"
  ui_box_close
}

ui_service_state() {
  local svc="$1"
  if systemctl is-active --quiet "$svc"; then
    printf "active"
  else
    printf "down"
  fi
}

ui_statusbar() {
  local host port lang
  host="$(proxy_host || true)"
  [[ -n "$host" ]] || host="unknown"
  port="$(proxy_port)"
  lang="$(lang_show 2>/dev/null || echo "$LANG_CODE")"
  ui_block_line "danted=$(ui_service_state danted) | fail2ban=$(ui_service_state fail2ban)"
  ui_block_line "host=$host | port=$port | lang=$lang"
  ui_box_close
}

ui_menu_item() {
  local n="$1"
  shift
  printf "  %-2s %s\n" "$n)" "$*"
}

ui_prompt() {
  local label="$1"
  read -r -p "  $label: " REPLY
}

ui_note() {
  printf "\n  %s\n\n" "$*"
}

ui_pause() {
  printf "\n"
  read -r -p "  $(t continue_prompt) " _
}

ui_section_spacer() {
  printf "\n"
}

ui_hotkeys_hint() {
  printf "  %s\n\n" "$(t hotkeys_hint)"
}

run_action() {
  safe_call "$@"
  ui_pause
}

match_lines() {
  local pattern="$1"
  if command -v rg >/dev/null 2>&1; then
    rg "$pattern" || true
  else
    grep -E "$pattern" || true
  fi
}

default_iface() {
  ip route show default 2>/dev/null | awk 'NR == 1 {print $5}'
}

timestamp_now() {
  date +%F-%H%M%S
}

ensure_runtime_dirs() {
  mkdir -p "$PROXYCTL_CACHE_DIR" "$PROXYCTL_BACKUP_DIR"
}

backup_file_if_exists() {
  local path="$1"
  [[ -f "$path" ]] || return 0
  ensure_runtime_dirs
  local sanitized ts backup
  sanitized="$(sed 's|/|_|g' <<< "$path" | sed 's|^_||')"
  ts="$(timestamp_now)"
  backup="${PROXYCTL_BACKUP_DIR}/${sanitized}.${ts}.bak"
  cp "$path" "$backup"
  echo "backup: $backup"
}

write_managed_file() {
  local path="$1"
  local content="$2"
  local tmp
  tmp="$(mktemp)"
  printf "%s\n" "$content" > "$tmp"
  mkdir -p "$(dirname "$path")"
  if [[ -f "$path" ]] && cmp -s "$tmp" "$path"; then
    rm -f "$tmp"
    echo "unchanged: $path"
    return
  fi
  backup_file_if_exists "$path"
  install -m 0644 "$tmp" "$path"
  rm -f "$tmp"
  echo "written: $path"
}

render_bootstrap_danted_conf() {
  local iface="$1"
  local port="$2"
  local udp_range="$3"
  cat <<EOF
logoutput: syslog
internal: ${iface} port = ${port}
external: ${iface}

socksmethod: pam.username
user.privileged: root
user.unprivileged: nobody
user.libwrap: nobody

client pass {
  from: 0.0.0.0/0 to: 0.0.0.0/0
  log: error connect disconnect
}

socks pass {
  from: 0.0.0.0/0 to: 0.0.0.0/0
  group: ${PROXY_GROUP}
  command: connect udpassociate
  udp.portrange: ${udp_range}
  log: error connect disconnect ioop
}
EOF
}

render_bootstrap_pam_danted() {
  cat <<EOF
# Restrict Dante auth to members of ${PROXY_GROUP}
# Order matters: group check + standard auth/account stacks
auth required pam_succeed_if.so user ingroup ${PROXY_GROUP}
auth include common-auth

account required pam_succeed_if.so user ingroup ${PROXY_GROUP}
account include common-account
EOF
}

render_bootstrap_fail2ban_filter() {
  cat <<'EOF'
[Definition]
failregex = pam_unix\(danted:auth\): authentication failure;.*rhost=<HOST>
ignoreregex =
EOF
}

render_bootstrap_fail2ban_jail() {
  local port="$1"
  cat <<EOF
[danted-auth]
enabled = true
filter = danted-auth
port = ${port}
logpath = /var/log/auth.log
backend = auto
findtime = 10m
maxretry = 6
bantime = 1h
action = ufw[name=danted-auth, port="${port}", protocol=tcp]
EOF
}

print_main_help() {
  cat <<'HELP'
proxyctl - CLI for Dante SOCKS5 management

Usage:
  proxyctl <group> <command> [options]

Command groups:
  bootstrap   Install and configure Dante stack on a clean server
  service     Manage danted service and logs
  user        Manage SOCKS users
  firewall    Manage UFW rules for SOCKS port
  config      View/change danted config basics
  lang        Show/set interface language (en/ru)
  audit       Security/activity audit summary
  usage       Per-user traffic usage from danted logs
  quota       Per-user traffic quota and enforcement
  doctor      Run quick health checks
  help        Show this help

Examples:
  sudo proxyctl bootstrap --proxy-password-random
  sudo proxyctl service status
  sudo proxyctl user add alice --random
  sudo proxyctl firewall allow-ip 203.0.113.10
  sudo proxyctl config port 2080
  sudo proxyctl lang set ru
  sudo proxyctl audit --since "24 hours ago"
  sudo proxyctl usage
  sudo proxyctl quota list
  sudo proxyctl doctor

Legacy aliases (still supported):
  status restart logs connections show-config ufw-status
  list-users adopt-user add-user set-password lock unlock del-user
  allow-ip revoke-ip
HELP
}

print_bootstrap_help() {
  cat <<'HELP'
Usage:
  proxyctl bootstrap [options]

Options:
  --iface <name>                 Outbound interface (default: auto-detect)
  --port <port>                  SOCKS5 TCP port (default: 1080)
  --udp-range <start-end>        UDP relay port range (default: 20000-20100)
  --proxy-user <username>        Initial proxy user (default: proxy-user)
  --proxy-password <password>    Set initial proxy password
  --proxy-password-random        Generate initial proxy password
  --reset-password               Reset password if proxy user already exists
  --format <generic|telegram|uri>
                                 Access output format (default: generic)
  --allow-ip <ip-or-cidr>        Restrict SOCKS access to this source (repeatable)
  --public                       Open SOCKS port publicly if no allow-ip rules are given
  --skip-fail2ban                Do not install/configure fail2ban for Dante
  --skip-ufw                     Do not touch UFW rules
  --dry-run                      Print intended actions without changing the system
HELP
}

